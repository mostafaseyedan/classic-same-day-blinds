FROM node:22-bullseye-slim

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY . .

RUN npm ci
RUN npm run build -w @blinds/commerce
RUN npm run build -w @blinds/ops-api
RUN npm run build -w @blinds/storefront

EXPOSE 8080

CMD ["sh", "-c", "echo 'Set Cloud Run command/args per service' && sleep 3600"]

