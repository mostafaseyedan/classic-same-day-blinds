ARG BASE_IMAGE=node:22-bullseye-slim
FROM ${BASE_IMAGE}

WORKDIR /app

COPY . .

ARG VITE_OPS_API_URL=http://localhost:4000
ARG VITE_STOREFRONT_URL=http://localhost:3000

ENV VITE_OPS_API_URL=${VITE_OPS_API_URL}
ENV VITE_STOREFRONT_URL=${VITE_STOREFRONT_URL}

RUN npm run build -w @blinds/commerce

ENV NODE_ENV=production

EXPOSE 9000

CMD ["sh", "-c", "npm run db:migrate -w @blinds/commerce && npm run start -w @blinds/commerce -- --host 0.0.0.0 --port ${PORT:-9000}"]
